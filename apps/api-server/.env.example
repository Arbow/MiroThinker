# MiroThinker HTTP API Configuration
# Copy this file to .env and fill in your actual API keys

# Tavily API Configuration
# Get your API key from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_BASE_URL=https://api.tavily.com

# Jina API Configuration (for web scraping)
# Get your API key from: https://jina.ai
JINA_API_KEY=your_jina_api_key_here
JINA_BASE_URL=https://r.jina.ai

# SiliconFlow API Configuration (GLM-5)
# Get your API key from: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/zai-org/GLM-5

# Server Configuration
PORT=8080
HOST=0.0.0.0
